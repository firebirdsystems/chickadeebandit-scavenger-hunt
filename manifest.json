{
  "id": "scavenger-hunt",
  "contexts": ["household", "shared_space"],
  "name": "Scavenger Hunt",
  "version": "1.0.0",
  "description": "Set a list of things to find, everyone hunts and submits photo proof in secret, then the big reveal — see everyone's finds at once and award points.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "games",
  "tags": ["scavenger", "hunt", "photos", "game", "family", "party"],
  "icon": "🔎",
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "hunts": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_owner_only": true
    },
    "tasks": {
      "kind": "inherit_visibility",
      "fk_column": "hunt_id",
      "parent_table": "hunts",
      "writer_column": "created_by",
      "insert_only_by_parent_column_member": "created_by"
    },
    "submissions": {
      "kind": "sealed_until",
      "fk_column": "hunt_id",
      "parent_table": "hunts",
      "writer_column": "member_id",
      "parent_status_column": "status",
      "visible_parent_status_values": ["closed"],
      "max_per_member": {
        "member_column": "member_id",
        "scope_columns": ["task_id"],
        "limit": 1
      },
      "frozen_when": {
        "status_column": "status",
        "locked_values": ["closed"]
      }
    },
    "awards": {
      "kind": "inherit_visibility",
      "fk_column": "hunt_id",
      "parent_table": "hunts",
      "writer_column": "awarded_by",
      "insert_only_by_parent_column_member": "created_by"
    }
  },
  "nav": { "label": "Hunt" },
  "resource_limits": {
    "max_db_bytes": 52428800
  }
}
